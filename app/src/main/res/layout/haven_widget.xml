<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <ImageView
        android:id="@+id/widget_avatar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:scaleType="centerCrop"
        android:src="@drawable/haven_logo" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/widget_avatar"
        android:layout_centerVertical="true"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_companion_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Companion"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_companion_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Location: Unknown"
            android:textColor="#D1C4E9"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/widget_last_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No messages yet."
            android:textColor="#E0E0E0"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="4dp" />

    </LinearLayout>

</RelativeLayout>
